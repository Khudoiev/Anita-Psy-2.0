{
  "name": "anita-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:up": "node-pg-migrate up",
    "migrate:create": "node-pg-migrate create",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern='__tests__/[^/]+\\.test\\.js$'",
    "test:integration": "jest --runInBand --testPathPattern='integration/'",
    "test:health": "jest --runInBand --testPathPattern='health'",
    "test:ci": "jest --runInBand --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:contract": "jest --runInBand --testPathPattern='contract/'",
    "test:security": "jest --runInBand --testPathPattern='security/'",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "lint:quick": "eslint routes/ services/ middleware/ --ext .js"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testRegex": "__tests__/.*\\.test\\.js$",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "routes/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "!**/node_modules/**"
    ]
  },
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ua-parser-js": "^1.0.37",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "eslint": "^8.57.1",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "supertest": "^6.3.4"
  }
}
